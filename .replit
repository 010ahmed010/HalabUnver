modules = ["nodejs-20"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start backend"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd client && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Start backend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd server && node server.js"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000

[deployment]
deploymentTarget = "static"
build = ["npm", "--prefix", "client", "run", "build"]
publicDir = "client/dist"

[userenv]

[userenv.shared]
PORT = "8000"
NODE_ENV = "development"
JWT_EXPIRES_IN = "7d"
CLIENT_ORIGIN = "http://localhost:5000"
